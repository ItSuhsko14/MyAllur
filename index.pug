body

	header#header.fixed-top
		nav.navbar.navbar-expand-lg.navbar-dark(style="background-color:black")
			.container
				a.navbar-brand(href="#")
					| Кінний клуб Аллюр
				button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navContent" aria-expanded="false" aria-label="Toggle navigation")
					span.navbar-toggler-icon
				.collapse.navbar-collapse#navContent
					ul.navbar-nav.me-auto.mb-3.mb-lg-0
						li.nav-item
							a.nav-link.active(href="#" aria-curent='page')
								| Головна
						li.nav-item
							a.nav-link(href="#")
								| Про нас
						li.nav-item
							a.nav-link(href="#")
								| Контакти
						



	.container.soc-icons
