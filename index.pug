body

	header#header
		nav.navbar.navbar-expand-lg.navbar-dark(style="background-color:#4d2723")
			.container
				a.navbar-brand(href="#")
					| Кінний клуб Аллюр
				button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navContent" aria-expanded="false" aria-label="Toggle navigation")
					span.navbar-toggler-icon
				.collapse.navbar-collapse#navContent
					ul.navbar-nav.me-auto.mb-3.mb-lg-0
						li.nav-item
							a.nav-link.active(href="#" aria-curent='page')
								| Головна
						li.nav-item
							a.nav-link(href="#")
								| Про нас
						li.nav-item
							a.nav-link(href="#")
								| Контакти
						
	.container.soc-icons
		.row.justify-content-around
			.col.text-center
				a(href='https://www.instagram.com/allurdnepr/' target='blank')
					i(class='fab fa-instagram')
			.col.text-center
				a(href='https://www.youtube.com/channel/UC86Zf95lmijWpG3m88abW-A/featured' target='blank')
					i(class='fab fa-youtube')
			.col.text-center
				a(href='https://www.tiktok.com/@oxy.allur' target='blank')
					i(class='fab fa-tiktok')
			.col.text-center
				a(href='https://www.facebook.com/allurdnepr/' target='blank')
					i(class='fab fa-facebook')
			.col.text-center
				a(href='https://viber.click/380984296885' target='blank')
					i(class='fab fa-viber')
			.col.text-center
				a(href='tel:+380667200846')
					i(class='fas fa-phone')

	.container.p-0.mb-2
		.row
			.col.text-center
				img(src='img/main-photo.jpg' alt='main-photo allur' class='img-fluid d-block mx-auto')


	.container.p-0.mb-2
		.row.gx-1.op
			.col
				img(class='img-fluid' src='img/horse-allur400x300.jpg' alt='Аллюр')
			.col
				img(class='img-fluid' src='img/horse-berta400x300.jpg' alt='Берта')
			.col
				img(class='img-fluid' src='img/horse-oscar400x300.jpg' alt='Оскар')
			.col
				img(class='img-fluid' src='img/horse-dolgojdaniy400x300.jpg' alt='Долгожданний')
			.col
				img(class='img-fluid' src='img/horse-plyama400x300.jpg' alt='Пляма')
			.col
				img(class='img-fluid' src='img/horse-verhovina400x300.jpg' alt='Верховина')

- var menu = [{src: 'img/training.jpg', text: 'тренування'},{src: 'img/svyata.jpg', text: 'кінне шоу та свята'},{src: 'img/photosession.jpg', text: 'фотосессії та зйомки кліпів'},{src: 'img/progulki.jpg', text: 'кінні прогулянки та походи'},{src: 'img/sertificate.jpg', text: 'сертифікати'},{src: 'img/price.jpg', text: 'прайс'}]

.container
	.row
		each el in menu
			.col-6.col-md-4.container-menu.p-0
				img(class='img-fluid img-menu' src=el.src)
				span.text-top
					h1
						|#{el.text}

	
	.container
		.row
			.col-12.col-sm-12.col-lg-3
				.row.h4.mt-3
					| Контакти:	
				.row
					| Адміністратор: <br>
					| (066) 720 08 46 <br>
					| (063) 873 90 18
				.row
					| Тренер: <br>
					| (098) 429 68 85 <br>
					| (095) 424 77 53

			.col-12.col-sm-12.col-lg-9
				.row.h4.mt-3
					| Місцеположення:
				.row
					| Україна, м.Дніпро, ж/м Ігрень, вул. Богородицька, 90
